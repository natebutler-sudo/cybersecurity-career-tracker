{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "database",
      "runtimeExecutable": "docker",
      "runtimeArgs": [
        "run",
        "--rm",
        "-p",
        "5432:5432",
        "-e",
        "POSTGRES_USER=career_user",
        "-e",
        "POSTGRES_PASSWORD=career_password",
        "-e",
        "POSTGRES_DB=career_tracker_dev",
        "-v",
        "$(pwd)/db/schema.sql:/docker-entrypoint-initdb.d/01-schema.sql",
        "-v",
        "$(pwd)/db/seed.sql:/docker-entrypoint-initdb.d/02-seed.sql",
        "postgres:14-alpine"
      ],
      "port": 5432
    },
    {
      "name": "backend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "backend",
      "port": 3001,
      "env": {
        "NODE_ENV": "development",
        "DATABASE_URL": "postgresql://career_user:career_password@localhost:5432/career_tracker_dev",
        "PORT": "3001"
      }
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "frontend",
      "port": 5173,
      "env": {
        "VITE_API_URL": "http://localhost:3001/api/v1"
      }
    }
  ]
}
